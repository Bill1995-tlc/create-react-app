# ──────────────────────────────────────────────
# Interactive Brokers Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and edit:
#   cp .env.example .env
#
# The adapter reads these at startup. Real env vars take precedence.

# TWS/IB Gateway host (DEFAULT: 127.0.0.1)
IB_HOST=127.0.0.1

# API socket port
#   TWS Paper:     7497  (DEFAULT)
#   TWS Live:      7496
#   Gateway Paper: 4002
#   Gateway Live:  4001
IB_PORT=7497

# API client ID — must be unique per connection
# Change this if you get "duplicate client ID" errors
IB_CLIENT_ID=1

# IB account ID (leave empty to use first available)
IB_ACCOUNT=

# Trading mode: paper or live
# This sets the DEFAULT port if IB_PORT is not explicitly set
IB_MODE=paper

# Connection timeout in seconds (DEFAULT: 10)
IB_TIMEOUT=10

# Read-only mode — if true, orders will be blocked
# Useful for monitoring-only scripts
IB_READONLY=false
